{
  "appId": "com.ai-image-gen.app",
  "productName": "AI Image Gen",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron/**/*",
    "!node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": "standalone",
      "filter": ["**/*", "!.next/cache/**"]
    },
    {
      "from": ".next/static",
      "to": "standalone/.next/static"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "AI Image Gen"
  }
}
