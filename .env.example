# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 初始管理员，多个邮箱用英文逗号分隔
ADMIN_EMAILS=admin@example.com

# 平台统一生图 API（服务端使用，不暴露给浏览器）
UPSTREAM_API_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-upstream-api-key
UPSTREAM_MODEL_ID=gpt-image-2
UPSTREAM_USE_FULL_URL=false

# 新用户默认每日生图额度
DEFAULT_DAILY_QUOTA=20

# Cloudflare Pages / Workers KV 绑定名：IMAGES_BUCKET
# 该绑定在 wrangler.toml 或 Cloudflare Pages 控制台配置